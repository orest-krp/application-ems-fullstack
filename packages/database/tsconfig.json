{
  "extends": "@ems-fullstack/typescript-config/nestjs.json",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "src",
    "esModuleInterop": true,
    "incremental": false,
    "outDir": "dist",
    "types": ["node"],
    "strictNullChecks": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "generated",
    "prisma"
  ]
}