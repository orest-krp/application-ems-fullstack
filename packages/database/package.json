  "devDependencies": {
    "@ems-fullstack/eslint-config": "workspace:*",
    "@ems-fullstack/typescript-config": "workspace:*",
    "@prisma/adapter-pg": "^7.5.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "pg": "^8.20.0",
    "prisma": "^7.5.0",
    "rimraf": "^5.0.5",
    "tsx": "4.21.0",
    "typescript": "5.5.4"
  }
}
