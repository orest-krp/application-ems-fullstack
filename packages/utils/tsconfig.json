{
  "extends": "@ems-fullstack/typescript-config/base",
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": "src",
    "esModuleInterop": true,
    "incremental": false,
    "outDir": "dist",
    "strictNullChecks": true
  },
  "include": ["src"],
  "experimentalDecorators": true,
  "emitDecoratorMetadata": true,
  "exclude": ["node_modules", "dist"]
}